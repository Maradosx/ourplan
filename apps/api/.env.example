# ── Database ──────────────────────────────────────────────────────────────────
# Local Postgres (development):
DATABASE_URL="postgresql://postgres:password@localhost:5432/ourplan?schema=public"
#
# Hosted Postgres on Supabase (production). Grab the connection string from the
# Supabase dashboard → Project Settings → Database, and reset the password there.
# Use the session pooler for serverless/long-running apps:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Dev-only: expose the password-reset token in the API response so the reset flow
# can be tested without an email provider. NEVER enable in production.
# EXPOSE_RESET_TOKEN=true

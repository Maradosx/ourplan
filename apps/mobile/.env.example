# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# Base URL of the OurPlan API (must include the /api/v1 prefix).
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Google Maps API key for the location picker (react-native-maps).
# Required only for native/dev builds that use the map. Restrict the key to the
# iOS bundle id and the Maps SDK in Google Cloud Console.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
